# W&B local server connection
# After running `task up`, visit http://localhost:8080 to create an account
# and retrieve your API key from the user settings page
WANDB_BASE_URL=http://localhost:8080
WANDB_API_KEY=your-api-key-here

# W&B project name (created automatically on first run)
WANDB_PROJECT=wandb-demo

# Training data config
TICKER=SPY
LOOKBACK_YEARS=5
